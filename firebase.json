{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "bakayise-uncedo",
    "public": "web/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/ice-config",
        "function": "getIceConfig"
      },
      {
        "source": "/verify-paystack",
        "function": "verifyPaystack"
      },
      {
        "source": "/finalize-session-billing",
        "function": "finalizeSessionBilling"
      },
      {
        "source": "/pay-outstanding-balance",
        "function": "payOutstandingBalance"
      },
      {
        "source": "/delete-payment-method",
        "function": "deletePaymentMethod"
      },
      {
        "source": "/verify-tutor-payout-account",
        "function": "verifyTutorPayoutAccount"
      },
      {
        "source": "/list-tutor-payout-banks",
        "function": "listTutorPayoutBanks"
      },
      {
        "source": "/pricing-quote",
        "function": "getPricingQuote"
      },
      {
        "source": "/sync-student-growth",
        "function": "syncStudentGrowth"
      },
      {
        "source": "/image-ocr",
        "function": "extractImageOcr"
      },
      {
        "source": "/classify-subject",
        "function": "classifySubject"
      },
      {
        "source": "/extract-attachment-ai",
        "function": "extractAttachmentAi"
      },
      {
        "source": "/stream-board-extraction",
        "function": "streamAttachmentAi"
      },
      {
        "source": "/save-academic-brain-feedback",
        "function": "saveAcademicBrainFeedback"
      },
      {
        "source": "/mobile-webview-auth",
        "function": "mobileWebviewAuth"
      },
      {
        "source": "/getTutorAgreement",
        "function": "getTutorAgreement"
      },
      {
        "source": "/acceptTutorAgreement",
        "function": "acceptTutorAgreement"
      },
      {
        "source": "/emailSignedTutorAgreement",
        "function": "emailSignedTutorAgreement"
      },
      {
        "source": "/publishTutorAgreementVersion",
        "function": "publishTutorAgreementVersion"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "emulators": {
    "auth": {
      "host": "0.0.0.0",
      "port": 9099
    },
    "firestore": {
      "host": "0.0.0.0",
      "port": 8080
    },
    "functions": {
      "host": "0.0.0.0",
      "port": 5001
    },
    "hosting": {
      "host": "0.0.0.0",
      "port": 5000
    },
    "storage": {
      "host": "0.0.0.0",
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "host": "0.0.0.0",
      "port": 4000
    },
    "singleProjectMode": true
  }
}
